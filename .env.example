# Sentri OT Configuration
# Copy to .env and customize

# Scan mode: passive (listen-only, default), active (Who-Is + optional TCP), simulate
SENTRI_OT_SCAN_MODE=passive

# Networks to scan (comma-separated CIDR). For the live BMS PC this is 192.168.1.0/24.
SENTRI_OT_SCAN_NETWORKS=

# Auto-scan interval in minutes (0 = manual only, default 60)
SENTRI_OT_SCAN_INTERVAL=60

# CORS allowed origins (comma-separated)
SENTRI_OT_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Database path (inside container /data volume)
SENTRI_OT_DB_PATH=/data/sentri_ot.db

# Preferred local BACnet NIC/IP. For the live BMS PC this is 192.168.1.205.
SENTRI_OT_BACNET_LOCAL_IP=192.168.1.205

# BACnet discovery mode for active/full scans: whois (send broadcast + listen), listen, full
SENTRI_OT_BACNET_DISCOVERY=whois

# Optional API key. Leave blank for local/demo mode; set for real deployments.
# Clients may send Authorization: Bearer <key> or X-API-Key: <key>.
SENTRI_OT_API_KEY=
